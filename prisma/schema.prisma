generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PositionRank {
  TECHNICIAN
  ENGINEER_I
  ENGINEER_II
  CHIEF_SPECIALIST
  SUB_DIRECTOR
  DIRECTOR
}

enum TaskKind {
  TOW_TRUCK
  SITE_INSPECTION
  LOGISTICS_RUN
  LAB_SAMPLE
  CONSTRUCTION_SUPPORT
  CONSTRUCTION_SITE
  ADMIN_PAPERWORK
  ROAD_PATROL
}

enum EvacuationStatus {
  DRAFT
  ACTIVE
  DELIVERED
  CLOSED
}

enum NotificationType {
  CALL_BASE
  BROADCAST
  TASK_ASSIGNED
  SYSTEM
  DISPATCH
  JOB_APPLICATION
  CIVIC_HELP
  STAFF_COMPLAINT
  ROAD_PATROL_REPORT
  PAYOUT_REQUEST
}

enum PayoutRequestKind {
  MATERIAL_HELP
  EVACUATION_PAY
  OTHER
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id               String       @id @default(cuid())
  nickname         String       @unique
  codeHash         String
  isAdmin          Boolean      @default(false)
  isDispatcher     Boolean      @default(false)
  positionRank     PositionRank @default(TECHNICIAN)
  department       String?
  displayName      String?
  xp               Int          @default(0)
  level            Int          @default(1)
  towTruckCert     Boolean      @default(false)
  driverCert       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  shifts            Shift[]
  tasks             WorkTask[]
  evacuations       Evacuation[]
  pings             LocationPing[]
  notifications     Notification[]
  dispatchCreated   DispatchCall[] @relation("DispatchCreated")
  dispatchReceived  DispatchCall[] @relation("DispatchReceived")
  dispatchReports   DispatchCall[] @relation("DispatchReportBy")
  civicAssigned     PublicAssistanceRequest[] @relation("CivicAssigned")
  radioSessions     RadioSession[]
  radioSignalsSent  RadioSignal[]  @relation("RadioSignalFrom")
  radioSignalsTo    RadioSignal[]  @relation("RadioSignalTo")
  examRegistrations ExamRegistration[] @relation("ExamStudent")
  examsGiven        ExamRegistration[] @relation("ExaminerRel")
  channelPosts        ChannelPost[]
  vehicleAssignments  VehicleAssignment[]
  disciplinesReceived DisciplineRecord[] @relation("DisciplineTarget")
  disciplinesIssued   DisciplineRecord[] @relation("DisciplineIssuer")
  patrolAsLeader      PatrolGroup?       @relation("PatrolGroupLeader")
  patrolAsPartner     PatrolGroup?       @relation("PatrolGroupPartner")
  patrolCheckpointDuty PatrolCheckpointDuty?
  roadPatrolReports   RoadPatrolReport[]
  roadClosures        RoadClosure[]
  vehicleRegistryAudits VehicleRegistryAudit[]
  payoutRequests      PayoutRequest[]
}

/// Заявка сотрудника на выплату (матпомощь, эвакуации, прочее)
model PayoutRequest {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          PayoutRequestKind
  details       String
  amountNote    String?
  status        PayoutRequestStatus @default(PENDING)
  adminNote     String?
  payoutDetails String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  resolvedAt    DateTime?

  @@index([userId, status])
  @@index([status, createdAt])
}

model VehicleRegistry {
  id        String   @id @default(cuid())
  plate     String   @unique
  model     String?
  owner     String?
  photoUrl  String?
  notes     String?
  createdAt DateTime @default(now())
  audits    VehicleRegistryAudit[]
}

/// История пополнения реестра ТС (кто и с какой причиной)
model VehicleRegistryAudit {
  id         String          @id @default(cuid())
  vehicleId  String
  vehicle    VehicleRegistry @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User            @relation(fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  reason     String?
  createdAt  DateTime        @default(now())

  @@index([createdAt])
  @@index([vehicleId])
}

model Shift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  tasks     WorkTask[]
}

model WorkTask {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId   String?
  shift     Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  kind      TaskKind
  title     String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  notes     String?
  evacuation Evacuation?
}

model Evacuation {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?          @unique
  task        WorkTask?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  plate       String
  ownerNickname String?
  pickupLat   Float?
  pickupLng   Float?
  violation   String
  description String?
  status      EvacuationStatus @default(DRAFT)
  photoUrls   String
  createdAt   DateTime         @default(now())
  closedAt    DateTime?
}

model LocationPing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  label     String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model DispatchCall {
  id        String    @id @default(cuid())
  creatorId String
  creator   User      @relation("DispatchCreated", fields: [creatorId], references: [id], onDelete: Cascade)
  targetId  String?
  target    User?     @relation("DispatchReceived", fields: [targetId], references: [id], onDelete: SetNull)
  title     String
  body      String
  lat       Float?
  lng       Float?
  endLat    Float?
  endLng    Float?
  status    String    @default("OPEN")
  reportText String?
  reportAt   DateTime?
  reportById String?
  reportBy   User?    @relation("DispatchReportBy", fields: [reportById], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  civicOrigin PublicAssistanceRequest?
}

/// Публичное обращение гражданина (раздел «Помощь» на сайте)
model PublicAssistanceRequest {
  id             String        @id @default(cuid())
  fullName       String
  category       String
  description    String
  phone          String
  lat            Float
  lng            Float
  endLat         Float?
  endLng         Float?
  status         String        @default("OPEN")
  dispatchCallId String?       @unique
  dispatchCall   DispatchCall? @relation(fields: [dispatchCallId], references: [id], onDelete: SetNull)
  assignedUserId String?
  assignedUser   User?         @relation("CivicAssigned", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
}

model RadioSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room           String
  isTransmitting Boolean  @default(false)
  lastHeartbeat  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, room])
  @@index([room, lastHeartbeat])
}

model RadioSignal {
  id         String    @id @default(cuid())
  room       String
  fromUserId String
  fromUser   User      @relation("RadioSignalFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String?
  toUser     User?     @relation("RadioSignalTo", fields: [toUserId], references: [id], onDelete: SetNull)
  type       String
  payload    String
  createdAt  DateTime  @default(now())
  consumedAt DateTime?

  @@index([room, createdAt])
  @@index([toUserId, consumedAt])
}

model ExamRegistration {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation("ExamStudent", fields: [userId], references: [id], onDelete: Cascade)
  kind       String
  status     String    @default("PENDING")
  testScore  Int?
  examNote   String?
  examinerId String?
  examiner   User?     @relation("ExaminerRel", fields: [examinerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  finishedAt DateTime?
}

model Channel {
  id    String        @id @default(cuid())
  slug  String        @unique
  title String
  posts ChannelPost[]
}

model VehicleAssignment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cid         String
  vehicleName String
  photoUrl    String?
  assignedAt  DateTime @default(now())
}

model DisciplineRecord {
  id         String   @id @default(cuid())
  targetId   String
  target     User     @relation("DisciplineTarget", fields: [targetId], references: [id], onDelete: Cascade)
  issuerId   String
  issuer     User     @relation("DisciplineIssuer", fields: [issuerId], references: [id], onDelete: Cascade)
  type       String
  reason     String
  createdAt  DateTime @default(now())
}

model ChannelPost {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  title     String
  body      String
  emoji     String?
  createdAt DateTime @default(now())
}

/// Заявка на собеседование (публичная форма на главной)
model JobApplication {
  id                String   @id @default(cuid())
  nickname          String
  gameLevel         String
  drugAddict        Boolean  @default(false)
  phone             String
  engineeringEdu    Boolean  @default(false)
  educationLevel    String?
  driverLicense     Boolean  @default(false)
  licenseCategory   String?
  interviewAt       DateTime
  expectedIncome    Int
  createdAt         DateTime @default(now())
}

/// Пара «дорожный патруль»: старший + напарник (одна машина)
model PatrolGroup {
  id         String   @id @default(cuid())
  leaderId   String   @unique
  leader     User     @relation("PatrolGroupLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  partnerId  String?  @unique
  partner    User?    @relation("PatrolGroupPartner", fields: [partnerId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

/// Заступление на стационарный блок-пост (id поста = PATROL_CHECKPOINTS.id)
model PatrolCheckpointDuty {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkpointId Int
  startedAt    DateTime @default(now())

  @@index([checkpointId])
}

/// Перекрытие / ограничение движения (метка на карте от патруля)
model RoadClosure {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  lat         Float
  lng         Float
  title       String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?
}

/// Отчёт дорожного патруля (проверка диспетчером)
model RoadPatrolReport {
  id                String    @id @default(cuid())
  authorId          String
  author            User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kind              String
  note              String    @default("")
  citizenNickname   String?
  photoUrls         String    @default("[]")
  lat               Float?
  lng               Float?
  status            String    @default("PENDING")
  reviewerId        String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime  @default(now())
}

/// Жалоба на сотрудника (публичная форма)
model StaffComplaint {
  id             String   @id @default(cuid())
  reporterName   String
  violatorName   String
  description    String
  evidenceUrls   String   @default("[]")
  phone          String
  status         String   @default("OPEN")
  adminNote      String?
  createdAt      DateTime @default(now())
}
